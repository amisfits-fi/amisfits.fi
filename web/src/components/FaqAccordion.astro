---
import { renderPT } from '@/lib/portable'
import { t } from '@/lib/i18n'
import type { FaqItem, Audience, Language } from '@/lib/queries'

interface Props {
  items:    FaqItem[]
  audience: Audience
  lang:     Language
}

const { items, audience, lang } = Astro.props
const tr = t(lang)
---

<section class="faq">
  <div class="faq__inner">
    <h2 class="faq__heading">{tr.faqHeading}</h2>

    <div class="faq__list">
      {items.map((item) => {
        // Audience-ehtologiikka: valitaan oikea vastaus
        const answerBlocks = audience === 'nuoret' ? item.answerYouth : item.answerAdult
        const answerHTML   = renderPT(answerBlocks)

        return (
          // Natiivi HTML details/summary – toimii ilman JavaScriptiä
          <details class="faq__item">
            <summary class="faq__question">
              <span>{item.question}</span>
              {/* Nuoli animoitavissa CSS:llä */}
              <span class="faq__icon" aria-hidden="true">▾</span>
            </summary>
            <div class="faq__answer" set:html={answerHTML} />
          </details>
        )
      })}
    </div>

  </div>
</section>
