# Kopioi tämä tiedosto nimellä .env ja täytä arvot
# Löydät arvot Sanity-projektin hallintapaneelista: sanity.io/manage

# Sanity-projektin tunniste (löytyy sanity.io/manage → projekti → Settings)
PUBLIC_SANITY_PROJECT_ID=

# Dataset (yleensä "production")
PUBLIC_SANITY_DATASET=production

# API-versio – pidä ajantasaisena
PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API -token (tarvitaan vain jos haetaan drafteja / esikatselua varten)
# Luo: sanity.io/manage → projekti → API → Tokens → Add API token
# HUOM: Älä koskaan commitoi tätä arvoa GitHubiin
SANITY_API_TOKEN=
