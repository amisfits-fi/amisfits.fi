---
import { urlFor } from '@/lib/sanity'
import type { PartnerLogo } from '@/lib/queries'

interface Props {
  logos: PartnerLogo[]
}

const { logos } = Astro.props
---

<section class="partners">
  <div class="partners__inner">
    <ul class="partners__grid" role="list">
      {logos.map((logo) => (
        <li class="partners__item">
          <img
            src={urlFor(logo.asset).width(200).url()}
            alt={logo.alt ?? 'Kumppanilogo'}
            loading="lazy"
            width="100"
            height="50"
          />
        </li>
      ))}
    </ul>
  </div>
</section>
