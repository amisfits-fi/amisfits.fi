---
import Layout        from '@/layouts/Layout.astro'
import Section       from '@/components/Section.astro'
import FaqAccordion  from '@/components/FaqAccordion.astro'
import PartnerLogos  from '@/components/PartnerLogos.astro'
import { getOnePager } from '@/lib/queries'
import type { Language, Audience } from '@/lib/queries'
import { LANGUAGES, AUDIENCES, audienceSlug, pathLang } from '@/lib/i18n'

// ── Staattinen reittilistaus – lokalisoidut audience-slugit per kieli ─────────
// Esim. /fi/nuoret, /sv/unga, /en/youth. URL:ssä käytetään ISO-kielikoodia
// (pathLang); Sanityn sisäinen koodi ja kanoninen audience välitetään propseina.
export function getStaticPaths() {
  return LANGUAGES.flatMap((lang) =>
    AUDIENCES.map((audience) => ({
      params: { lang: pathLang(lang), audience: audienceSlug(lang, audience) },
      props:  { lang, audience },
    }))
  )
}

// ── Hae Sanitystä oikea dokumentti ───────────────────────────────────────────
const { lang, audience } = Astro.props as { lang: Language; audience: Audience }
const page = await getOnePager(lang)
---

<Layout lang={lang} audience={audience}>

  {/* Sektiot – audience-ehtologiikka tapahtuu Section-komponentissa */}
  {page.sections.map((section) => (
    <Section section={section} audience={audience} lang={lang} />
  ))}

  {/* FAQ-haitari */}
  {page.faq?.length > 0 && (
    <FaqAccordion items={page.faq} audience={audience} lang={lang} />
  )}

  {/* Kumppanilogot */}
  {page.partnerLogos?.length > 0 && (
    <PartnerLogos logos={page.partnerLogos} lang={lang} />
  )}

</Layout>
