---
import type { Language, Audience } from '@/lib/queries'
import { LANGUAGES, LANG_LABEL, htmlLang, audienceSlug, t } from '@/lib/i18n'
import '@/styles/global.css'

interface Props {
  lang:     Language
  audience: Audience
  title?:   string
}

const { lang, audience, title = 'amisfits.fi' } = Astro.props
const tr = t(lang)

// Kohderyhmävaihtoehto (sama kieli, eri kohderyhmä) – lokalisoitu slug + otsikko
const otherAudience      = audience === 'nuoret' ? 'aikuiset' : 'nuoret'
const otherAudienceLabel = tr.audienceLabel[otherAudience]
const currentLabel       = tr.audienceLabel[audience]

// Kielivalitsin – sama kohderyhmä, eri kieli (kunkin kielen oma slug)
const languages = LANGUAGES.map((code) => ({
  code,
  label: LANG_LABEL[code],
  href:  `/${code}/${audienceSlug(code, audience)}`,
}))
---

<!doctype html>
<html lang={htmlLang(lang)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={tr.metaDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- CSS injected by Astro via import in frontmatter -->
  </head>

  <body>
    <!-- ── Navigaatio ───────────────────────────────────────── -->
    <nav class="nav">
      <div class="nav__audiences">
        <span class="nav__audience nav__audience--active">{currentLabel}</span>
        <a
          class="nav__audience"
          href={`/${lang}/${audienceSlug(lang, otherAudience)}`}
        >{otherAudienceLabel}</a>
      </div>

      <div class="nav__languages">
        {languages.map(l => (
          <a
            class:list={['nav__lang', { 'nav__lang--active': l.code === lang }]}
            href={l.href}
          >{l.label}</a>
        ))}
      </div>
    </nav>

    <!-- ── Pääsisältö ───────────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ───────────────────────────────────────────── -->
    <footer class="footer">
      <div class="footer__inner">
        <div>
          <p class="footer__wordmark">amisfits</p>
        </div>
        <div>
          <p class="footer__text">
            {tr.footerPre}
            <a href="https://www.sivista.fi" target="_blank" rel="noopener noreferrer" style="color: inherit;">
              Sivistysala ry (Sivista)
            </a>
            {tr.footerPost}
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
