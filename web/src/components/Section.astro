---
import { toHTML } from '@portabletext/to-html'
import type { Section, Audience } from '@/lib/queries'

interface Props {
  section:  Section
  audience: Audience
}

const { section, audience } = Astro.props

// ── Audience-ehtologiikka – valitaan oikea sisältö ───────────────────────────
const summary  = audience === 'nuoret' ? section.summaryYouth  : section.summaryAdult
const expanded = audience === 'nuoret' ? section.expandedYouth : section.expandedAdult

const summaryHTML  = summary?.length  ? toHTML(summary)  : ''
const expandedHTML = expanded?.length ? toHTML(expanded) : ''

// Taustaväri CSS-luokkana
const bgClass = `section--${section.backgroundColor}` // section--pink / section--yellow / section--blue

// Näyttöotsikko SVG -tiedostomapping
// mobile: valinnainen — jos määritelty, käytetään <picture> + <source media>
const displayGraphicMap: Record<string, { desktop: string; mobile?: string }> = {
  pink:   { desktop: '/images/Teema1_desktop.svg', mobile: '/images/Teema1_mobiili.svg' },
  yellow: { desktop: '/images/Amis-avaa-ovia.svg' },
  blue:   { desktop: '/images/Amis-aktivoi-unelmasi.svg' },
}
const graphic = section.backgroundColor
  ? displayGraphicMap[section.backgroundColor]
  : undefined

// YouTube-URL embed-muotoon: tukee sekä watch?v=ID että youtu.be/ID
function toEmbed(url: string): string {
  const ytMatch = url.match(/(?:v=|youtu\.be\/)([A-Za-z0-9_-]{11})/)
  return ytMatch ? `https://www.youtube.com/embed/${ytMatch[1]}` : url
}
---

{/* ── Värillinen sektio ─────────────────────────────────────── */}
<section class={`section ${bgClass}`}>

  {/* Näyttöotsikko SVG – sektiön yläosassa */}
  {graphic && (
    <div class="section__display-graphic">
      {graphic.mobile ? (
        /* Desktop + mobiili eri kuva — <picture> lataa vain tarvittavan */
        <picture>
          <source media="(min-width: 641px)" srcset={graphic.desktop} />
          <img
            src={graphic.mobile}
            alt={section.displayHeadline ?? ''}
            class="section__display-img"
            loading="lazy"
            decoding="async"
          />
        </picture>
      ) : (
        /* Yksi kuva kaikille näytöille */
        <img
          src={graphic.desktop}
          alt={section.displayHeadline ?? ''}
          class="section__display-img"
          loading="lazy"
          decoding="async"
        />
      )}
    </div>
  )}

  <div class="section__inner">

    {/* YouTube-video (valinnainen) */}
    {section.video && (
      <div class="section__video-area">
        <div class="section__video">
          <iframe
            src={toEmbed(section.video)}
            title={section.headline}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          />
        </div>
      </div>
    )}

    {!section.video && (
      <div class="section__video-area">
        <div class="section__video-placeholder">Video tulossa</div>
      </div>
    )}

    {/* Iso sisältöotsikko */}
    <h2 class="section__headline">{section.headline}</h2>

    {/* Tiivistelmä – aina näkyvissä */}
    {summaryHTML && (
      <div class="section__summary" set:html={summaryHTML} />
    )}

    {/* Laajennettu sisältö – haitari, natiivi HTML, ei JavaScriptiä */}
    {expandedHTML && (
      <details class="section__details">
        <summary class="section__cta">
          <span class="section__cta-pill">
            LUE LISÄÄ
            <i class="section__cta-icon" aria-hidden="true">▾</i>
          </span>
        </summary>
        <div class="section__expanded" set:html={expandedHTML} />
      </details>
    )}

    {/* AMISFITS-testi CTA */}
    <p class="section__test-cta">
      Sopiiko amis sinulle?{' '}
      {section.testCtaUrl
        ? <a href={section.testCtaUrl} class="section__test-link">Tee 2 min AMISFITS-testi →</a>
        : <span class="section__test-link section__test-link--placeholder">Tee 2 min AMISFITS-testi →</span>
      }
    </p>

  </div>
</section>
